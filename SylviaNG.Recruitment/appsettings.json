{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    //"Provider": "SqlServer",
    //"ConnectionString": "Server=192.168.1.212;Database=recruitment_db;User Id=sa;Password=your-password;TrustServerCertificate=true;"
    "Provider": "Postgresql",
    "ConnectionString": "Host=192.168.1.212;Port=5432;Database=recruitment_db;Username=postgres;Password=sylviang"
  },
  "Keycloak": {
    "Authority": "http://192.168.1.210:8082/realms/sylviang",
    "ClientId": "sylviang-api",
    // Do NOT commit a real value here. Set it locally in appsettings.Development.json
    // (gitignored) or via 'dotnet user-secrets set "Keycloak:ClientSecret" "<value>"',
    // and via your normal secret store (Key Vault, env var, etc.) in other environments.
    "ClientSecret": "",
    "RequireHttpsMetadata": false,
    // When true, self-registered candidates must verify their email before first login
    // (US-001 AC2). Requires realm SMTP configured; disable in local dev.
    "RequireEmailVerification": true
  },
  "Jwt": {
    "Local": {
      // Temporary, hardcoded-login-only signing key. Remove once real Keycloak-issued
      // logins (EP-15/EP-16) replace this local auth scheme.
      // Do NOT commit a real value here. Set it locally with:
      //   dotnet user-secrets set "Jwt:Local:SigningKey" "<a-long-random-string>" --project SylviaNG.Recruitment
      // and via your normal secret store (Key Vault, env var, etc.) in other environments.
      "SigningKey": "",
      "Issuer": "sylviang-recruitment-local-auth",
      "Audience": "sylviang-recruitment-api",
      "ExpiryMinutes": 60
    }
  },
  "Kafka": {
    "BootstrapServers": "192.168.1.210:9092",
    "GroupId": "sylviang-recruitment-employee-sync"
  },
  "RegionalSettings": {
    "TimezoneId": "Asia/Dhaka"
  },
  "ApiSettings": {
    "EmployeeApiUrl": "http://localhost:5298/employee/",
    "CoreApiUrl": "http://localhost:5200/core/",
    "LeaveApiUrl": "http://localhost:5204/leave/"
  },
  "GrpcServices": {
    "CoreService": {
      "Url": "http://localhost:7000"
    }
  },
  "FileStorage": {
    "RootPath": "wwwroot/uploads/job-postings",
    "MaxFileSizeMB": 10,
    "AllowedExtensions": [ ".pdf", ".doc", ".docx" ],
    "Applications": {
      "RootPath": "wwwroot/uploads/applications",
      "MaxFileSizeMB": 10,
      "AllowedExtensions": [ ".pdf", ".doc", ".docx" ]
    }
  },
  "CandidatePhotoSignature": {
    "MaxFileSizeMB": 2,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png" ]
  },
  "CandidateDocuments": {
    "MaxFileSizeMB": 10,
    "AllowedExtensions": [ ".pdf", ".jpg", ".jpeg", ".png", ".docx" ]
  },
  // AI-Powered Auto-Shortlisting (US-046): "Manual" (deterministic, no external calls) or "Ai"
  // (Groq). Flip this one value to swap implementations, no code change.
  "ShortlistScoring": {
    "Provider": "Manual"
  },
  // Resume upload auto-fill parsing: "Heuristic" (free, local, regex-based) or "Ai" (Groq).
  // Ai falls back to Heuristic in-process if Groq is unavailable - never fails the upload.
  "ResumeParsing": {
    "Provider": "Ai"
  },
  "Groq": {
    // Do NOT commit a real value here. Set it locally in appsettings.Development.json
    // (gitignored) or via 'dotnet user-secrets set "Groq:ApiKey" "<value>"',
    // and via your normal secret store (Key Vault, env var, etc.) in other environments.
    "ApiKey": "",
    "BaseUrl": "https://api.groq.com/openai/v1",
    "Model": "llama-3.1-8b-instant",
    "Temperature": 0.2,
    "TimeoutSeconds": 20,
    "MaxConcurrentRequests": 5
  },
  "SslCommerz": {
    "StoreId": "",
    // Do NOT commit a real value here. Set it locally in appsettings.Development.json
    // (gitignored) or via 'dotnet user-secrets set "SslCommerz:StorePassword" "<value>"',
    // and via your normal secret store (Key Vault, env var, etc.) in other environments.
    "StorePassword": "",
    "ApiBaseUrl": "https://sandbox.sslcommerz.com",
    "IsSandbox": true,
    "BackendBaseUrl": "http://localhost:5208",
    "FrontendReturnBaseUrl": "http://localhost:4600"
  },
  "ExamQuestionImport": {
    "MaxFileSizeMB": 5,
    "AllowedExtensions": [ ".xlsx", ".csv" ]
  }
}
